# AgentSafe localnet setup
# Copy this file to .env, then replace the required values:
#   cp .env.example .env

# Required: public address of the wallet that will receive SOL and Fake USDC.
PHANTOM_WALLET=CHANGE_ME_PHANTOM_PUBLIC_KEY

# Solana local validator RPC endpoint.
RPC_URL=http://localhost:8899

# Amount of SOL to airdrop to both the local CLI wallet and PHANTOM_WALLET.
AIRDROP_AMOUNT=100

# Amount of Fake USDC to mint to PHANTOM_WALLET.
MINT_AMOUNT=1000000

# Deterministic mint keypair used for the demo token.
MINT_KEYPAIR=fake_usdc_mint.json

# Fake USDC uses six decimals, matching the usual USDC display format.
TOKEN_DECIMALS=6

# Keypair that pays for mint and token-account creation.
FEE_PAYER=~/.config/solana/id.json

# Keypair that is allowed to mint more Fake USDC.
MINT_AUTHORITY_KEYPAIR=~/.config/solana/id.json

# Optional frontend values.
# setup_localnet.sh writes these values to web/.env.local after the mint exists.
NEXT_PUBLIC_SOLANA_RPC_URL=http://localhost:8899
NEXT_PUBLIC_DEMO_TOKEN_MINT=
